generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ─── Enums ──────────────────────────────────────────────────────────────────

enum AdminRole {
  super_admin
  admin
  support
  viewer
}

enum OrgType {
  government
  law_enforcement
  corporate
  academic
  private_lab
  individual
}

enum ContactRole {
  primary
  billing
  technical
  decision_maker
}

enum LicenseType {
  trial
  perpetual
  time_limited
  organization
}

enum LicenseTier {
  individual
  team
  enterprise
  government
}

enum LicenseStatus {
  issued
  active
  suspended
  revoked
  expired
}

enum ActorType {
  admin
  system
  desktop_app
}

enum ReleaseChannel {
  stable
  beta
  rc
}

enum ReleaseSeverity {
  critical
  recommended
  optional
}

enum Platform {
  windows
  linux
  android
}

enum DownloadType {
  manual
  auto_update
  api
}

enum AnnouncementType {
  info
  warning
  critical
  maintenance
}

enum TicketCategory {
  bug
  feature
  question
  other
  technical
  billing
  license
  general
}

enum TicketPriority {
  low
  medium
  high
  critical
}

enum TicketStatus {
  open
  in_progress
  waiting
  resolved
  closed
}

enum TicketSenderType {
  user
  support
  system
}

enum TrialRequestStatus {
  pending
  approved
  rejected
}

// ─── Models ─────────────────────────────────────────────────────────────────

model AdminUser {
  id           String    @id @default(uuid()) @db.VarChar(36)
  email        String    @unique @db.VarChar(255)
  passwordHash String    @map("password_hash") @db.VarChar(255)
  name         String    @db.VarChar(255)
  role         AdminRole @default(viewer)
  isActive     Boolean   @default(true) @map("is_active")
  mfaSecret    String?   @map("mfa_secret") @db.VarChar(255)
  lastLoginAt  DateTime? @map("last_login_at")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  sessions      AdminSession[]
  issuedLicenses License[]       @relation("IssuedByAdmin")
  auditLogs     AuditLog[]
  announcements Announcement[]   @relation("AnnouncementCreator")
  trialReviews  TrialRequest[]   @relation("TrialReviewer")

  @@map("admin_users")
}

model AdminSession {
  id               String   @id @default(uuid()) @db.VarChar(36)
  adminUserId      String   @map("admin_user_id") @db.VarChar(36)
  tokenHash        String   @map("token_hash") @db.VarChar(255)
  refreshTokenHash String   @map("refresh_token_hash") @db.VarChar(255)
  expiresAt        DateTime @map("expires_at")
  refreshExpiresAt DateTime @map("refresh_expires_at")
  ipAddress        String?  @map("ip_address") @db.VarChar(45)
  userAgent        String?  @map("user_agent") @db.VarChar(512)
  createdAt        DateTime @default(now()) @map("created_at")

  admin AdminUser @relation(fields: [adminUserId], references: [id], onDelete: Cascade)

  @@index([adminUserId])
  @@index([tokenHash])
  @@map("admin_sessions")
}

model Organization {
  id       String  @id @default(uuid()) @db.VarChar(36)
  name     String  @db.VarChar(255)
  slug     String  @unique @db.VarChar(255)
  orgType  OrgType @map("org_type")
  email    String? @db.VarChar(255)
  phone    String? @db.VarChar(30)
  address  String? @db.VarChar(512)
  city     String? @db.VarChar(100)
  state    String? @db.VarChar(100)
  country  String  @default("IN") @db.VarChar(10)
  gstin    String? @db.VarChar(20)
  panNumber String? @map("pan_number") @db.VarChar(20)
  isActive Boolean @default(true) @map("is_active")
  notes    String? @db.Text
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  contacts     Contact[]
  licenses     License[]
  events       LicenseEvent[]
  downloads    Download[]
  tickets      SupportTicket[]

  @@map("organizations")
}

model Contact {
  id             String      @id @default(uuid()) @db.VarChar(36)
  organizationId String      @map("organization_id") @db.VarChar(36)
  name           String      @db.VarChar(255)
  email          String?     @db.VarChar(255)
  phone          String?     @db.VarChar(30)
  designation    String?     @db.VarChar(255)
  role           ContactRole @default(primary)
  isActive       Boolean     @default(true) @map("is_active")
  createdAt      DateTime    @default(now()) @map("created_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@map("contacts")
}

model License {
  id                  String        @id @default(uuid()) @db.VarChar(36)
  licenseKey          String        @unique @map("license_key") @db.VarChar(30)
  licenseType         LicenseType   @map("license_type")
  tier                LicenseTier
  organizationId      String?       @map("organization_id") @db.VarChar(36)
  status              LicenseStatus @default(issued)
  maxActivations      Int           @default(1) @map("max_activations")
  currentActivations  Int           @default(0) @map("current_activations")
  validFrom           DateTime      @map("valid_from")
  validUntil          DateTime?     @map("valid_until")
  featureFlags        Json          @default("{}") @map("feature_flags")
  issuedById          String?       @map("issued_by_id") @db.VarChar(36)
  notes               String?       @db.Text
  purchaseOrderNumber String?       @map("purchase_order_number") @db.VarChar(100)
  invoiceNumber       String?       @map("invoice_number") @db.VarChar(100)
  amountInr           Decimal?      @map("amount_inr") @db.Decimal(12, 2)
  createdAt           DateTime      @default(now()) @map("created_at")
  updatedAt           DateTime      @updatedAt @map("updated_at")

  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  issuedBy     AdminUser?    @relation("IssuedByAdmin", fields: [issuedById], references: [id], onDelete: SetNull)
  activations  LicenseActivation[]
  events       LicenseEvent[]

  @@index([organizationId])
  @@index([issuedById])
  @@index([status])
  @@index([licenseType])
  @@map("licenses")
}

model LicenseActivation {
  id                  String    @id @default(uuid()) @db.VarChar(36)
  licenseId           String    @map("license_id") @db.VarChar(36)
  hardwareFingerprint String    @map("hardware_fingerprint") @db.VarChar(255)
  machineName         String?   @map("machine_name") @db.VarChar(255)
  osInfo              String?   @map("os_info") @db.VarChar(255)
  userEmail           String?   @map("user_email") @db.VarChar(255)
  appVersion          String?   @map("app_version") @db.VarChar(30)
  ipAddress           String?   @map("ip_address") @db.VarChar(45)
  isActive            Boolean   @default(true) @map("is_active")
  activatedAt         DateTime  @default(now()) @map("activated_at")
  deactivatedAt       DateTime? @map("deactivated_at")
  lastValidatedAt     DateTime? @map("last_validated_at")
  lastHeartbeatAt     DateTime? @map("last_heartbeat_at")
  validationToken     String?   @map("validation_token") @db.VarChar(512)

  license License        @relation(fields: [licenseId], references: [id], onDelete: Cascade)
  events  LicenseEvent[]

  @@unique([licenseId, hardwareFingerprint])
  @@index([licenseId])
  @@index([hardwareFingerprint])
  @@map("license_activations")
}

model LicenseEvent {
  id             BigInt     @id @default(autoincrement())
  licenseId      String?    @map("license_id") @db.VarChar(36)
  activationId   String?    @map("activation_id") @db.VarChar(36)
  organizationId String?    @map("organization_id") @db.VarChar(36)
  action         String     @db.VarChar(100)
  actorType      ActorType  @map("actor_type")
  actorId        String?    @map("actor_id") @db.VarChar(36)
  actorEmail     String?    @map("actor_email") @db.VarChar(255)
  actorIp        String?    @map("actor_ip") @db.VarChar(45)
  oldValues      Json?      @map("old_values")
  newValues      Json?      @map("new_values")
  metadata       Json?
  createdAt      DateTime   @default(now()) @map("created_at")

  license      License?            @relation(fields: [licenseId], references: [id], onDelete: SetNull)
  activation   LicenseActivation?  @relation(fields: [activationId], references: [id], onDelete: SetNull)
  organization Organization?       @relation(fields: [organizationId], references: [id], onDelete: SetNull)

  @@index([licenseId])
  @@index([activationId])
  @@index([organizationId])
  @@index([action])
  @@index([createdAt])
  @@map("license_events")
}

model Heartbeat {
  id                  BigInt   @id @default(autoincrement())
  licenseKey          String   @map("license_key") @db.VarChar(30)
  hardwareFingerprint String   @map("hardware_fingerprint") @db.VarChar(255)
  appVersion          String   @map("app_version") @db.VarChar(30)
  casesCreated        Int      @default(0) @map("cases_created")
  acquisitions        Int      @default(0)
  reportsGenerated    Int      @default(0) @map("reports_generated")
  ipAddress           String?  @map("ip_address") @db.VarChar(45)
  createdAt           DateTime @default(now()) @map("created_at")

  @@index([licenseKey])
  @@index([createdAt])
  @@map("heartbeats")
}

model Release {
  id            String          @id @default(uuid()) @db.VarChar(36)
  version       String          @unique @db.VarChar(30)
  channel       ReleaseChannel  @default(stable)
  severity      ReleaseSeverity @default(optional)
  title         String          @db.VarChar(255)
  releaseNotes  String?         @map("release_notes") @db.Text
  gitCommitSha  String?         @map("git_commit_sha") @db.VarChar(64)
  workflowRunId BigInt?         @map("workflow_run_id")
  minVersion    String?         @map("min_version") @db.VarChar(30)
  forceUpdate   Boolean         @default(false) @map("force_update")
  isBlocked     Boolean         @default(false) @map("is_blocked")
  blockReason   String?         @map("block_reason") @db.VarChar(512)
  publishedAt   DateTime?       @map("published_at")
  createdAt     DateTime        @default(now()) @map("created_at")
  updatedAt     DateTime        @updatedAt @map("updated_at")

  assets        ReleaseAsset[]
  rolloutPolicy RolloutPolicy?

  @@index([channel])
  @@map("releases")
}

model ReleaseAsset {
  id          String   @id @default(uuid()) @db.VarChar(36)
  releaseId   String   @map("release_id") @db.VarChar(36)
  platform    Platform
  arch        String   @default("x86_64") @db.VarChar(20)
  packageType String   @map("package_type") @db.VarChar(30)
  filename    String   @db.VarChar(255)
  fileSize    BigInt   @map("file_size")
  sha256Hash  String   @map("sha256_hash") @db.VarChar(64)
  downloadUrl String   @map("download_url") @db.VarChar(1024)
  signature   String?  @db.Text
  createdAt   DateTime @default(now()) @map("created_at")

  release   Release    @relation(fields: [releaseId], references: [id], onDelete: Cascade)
  downloads Download[]

  @@index([releaseId])
  @@map("release_assets")
}

model Download {
  id             BigInt       @id @default(autoincrement())
  assetId        String       @map("asset_id") @db.VarChar(36)
  licenseKey     String?      @map("license_key") @db.VarChar(30)
  organizationId String?      @map("organization_id") @db.VarChar(36)
  ipAddress      String?      @map("ip_address") @db.VarChar(45)
  userAgent      String?      @map("user_agent") @db.VarChar(512)
  downloadType   DownloadType @default(manual) @map("download_type")
  createdAt      DateTime     @default(now()) @map("created_at")

  asset        ReleaseAsset  @relation(fields: [assetId], references: [id], onDelete: Cascade)
  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)

  @@index([assetId])
  @@index([createdAt])
  @@map("downloads")
}

model Announcement {
  id               String           @id @default(uuid()) @db.VarChar(36)
  title            String           @db.VarChar(255)
  message          String           @db.Text
  announcementType AnnouncementType @default(info) @map("announcement_type")
  targetOrgIds     Json?            @map("target_org_ids")
  targetTiers      Json?            @map("target_tiers")
  targetVersions   Json?            @map("target_versions")
  actionUrl        String?          @map("action_url") @db.VarChar(1024)
  actionLabel      String?          @map("action_label") @db.VarChar(100)
  dismissible      Boolean          @default(true)
  priority         Int              @default(0)
  startsAt         DateTime         @map("starts_at")
  expiresAt        DateTime?        @map("expires_at")
  isActive         Boolean          @default(true) @map("is_active")
  createdById      String?          @map("created_by_id") @db.VarChar(36)
  createdAt        DateTime         @default(now()) @map("created_at")
  updatedAt        DateTime         @updatedAt @map("updated_at")

  createdBy AdminUser? @relation("AnnouncementCreator", fields: [createdById], references: [id], onDelete: SetNull)

  @@index([isActive, startsAt])
  @@map("announcements")
}

model SupportTicket {
  id             String         @id @default(uuid()) @db.VarChar(36)
  ticketNumber   String         @unique @map("ticket_number") @db.VarChar(20)
  licenseKey     String         @map("license_key") @db.VarChar(30)
  organizationId String?        @map("organization_id") @db.VarChar(36)
  subject        String         @db.VarChar(512)
  category       TicketCategory @default(other)
  priority       TicketPriority @default(medium)
  status         TicketStatus   @default(open)
  createdAt      DateTime       @default(now()) @map("created_at")
  updatedAt      DateTime       @updatedAt @map("updated_at")
  closedAt       DateTime?      @map("closed_at")
  assignedToId   String?        @map("assigned_to_id") @db.VarChar(36)

  organization Organization?   @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  messages     TicketMessage[]

  @@index([ticketNumber])
  @@index([licenseKey])
  @@index([status])
  @@index([assignedToId])
  @@map("support_tickets")
}

model TicketMessage {
  id         String           @id @default(uuid()) @db.VarChar(36)
  ticketId   String           @map("ticket_id") @db.VarChar(36)
  message    String           @db.Text
  senderType TicketSenderType @map("sender_type")
  senderName String           @map("sender_name") @db.VarChar(255)
  isInternal Boolean          @default(false) @map("is_internal")
  createdAt  DateTime         @default(now()) @map("created_at")

  ticket SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@index([ticketId])
  @@map("ticket_messages")
}

model AuditLog {
  id           BigInt   @id @default(autoincrement())
  adminUserId  String?  @map("admin_user_id") @db.VarChar(36)
  action       String   @db.VarChar(100)
  resourceType String   @map("resource_type") @db.VarChar(50)
  resourceId   String?  @map("resource_id") @db.VarChar(36)
  oldValues    Json?    @map("old_values")
  newValues    Json?    @map("new_values")
  ipAddress    String?  @map("ip_address") @db.VarChar(45)
  userAgent    String?  @map("user_agent") @db.VarChar(512)
  createdAt    DateTime @default(now()) @map("created_at")

  admin AdminUser? @relation(fields: [adminUserId], references: [id], onDelete: SetNull)

  @@index([adminUserId])
  @@index([action])
  @@index([resourceType])
  @@index([createdAt])
  @@map("audit_logs")
}

model Setting {
  id        String   @id @default(uuid()) @db.VarChar(36)
  key       String   @unique @db.VarChar(100)
  value     String   @db.Text
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("settings")
}

model TrialRequest {
  id                  String             @id @default(uuid()) @db.VarChar(36)
  fullName            String             @map("full_name") @db.VarChar(255)
  email               String             @db.VarChar(255)
  phone               String?            @db.VarChar(30)
  organization        String             @db.VarChar(255)
  organizationType    String             @map("organization_type") @db.VarChar(50)
  designation         String?            @db.VarChar(255)
  department          String?            @db.VarChar(255)
  purpose             String             @db.Text
  expectedVolume      String?            @map("expected_volume") @db.VarChar(100)
  hardwareFingerprint String             @map("hardware_fingerprint") @db.VarChar(255)
  machineName         String             @map("machine_name") @db.VarChar(255)
  osInfo              String             @map("os_info") @db.VarChar(255)
  appVersion          String             @map("app_version") @db.VarChar(30)
  status              TrialRequestStatus @default(pending)
  approvedLicenseKey  String?            @map("approved_license_key") @db.VarChar(30)
  rejectionReason     String?            @map("rejection_reason") @db.Text
  createdAt           DateTime           @default(now()) @map("created_at")
  reviewedAt          DateTime?          @map("reviewed_at")
  reviewedById        String?            @map("reviewed_by_id") @db.VarChar(36)

  reviewedBy AdminUser? @relation("TrialReviewer", fields: [reviewedById], references: [id], onDelete: SetNull)

  @@index([hardwareFingerprint])
  @@index([email])
  @@index([status])
  @@map("trial_requests")
}

// ─── Rollout Engine Models ─────────────────────────────────────────────────

model RolloutPolicy {
  id            String   @id @default(uuid()) @db.VarChar(36)
  releaseId     String   @unique @map("release_id") @db.VarChar(36)
  release       Release  @relation(fields: [releaseId], references: [id], onDelete: Cascade)
  strategy      String   @default("immediate") @db.VarChar(30) // immediate, staged, targeted
  status        String   @default("active") @db.VarChar(30)    // active, paused, completed, cancelled
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  stages RolloutStage[]

  @@index([status])
  @@map("rollout_policies")
}

model RolloutStage {
  id            String    @id @default(uuid()) @db.VarChar(36)
  rolloutId     String    @map("rollout_id") @db.VarChar(36)
  rollout       RolloutPolicy @relation(fields: [rolloutId], references: [id], onDelete: Cascade)
  stageOrder    Int       @map("stage_order")
  percentage    Int       // 0-100
  targetOrgIds  Json?     @map("target_org_ids")   // specific org IDs to include
  targetTiers   Json?     @map("target_tiers")      // specific tiers to include
  minSoakHours  Int       @default(24) @map("min_soak_hours")
  activatedAt   DateTime? @map("activated_at")
  completedAt   DateTime? @map("completed_at")

  @@unique([rolloutId, stageOrder])
  @@index([rolloutId])
  @@map("rollout_stages")
}

model BlockedVersion {
  id             String   @id @default(uuid()) @db.VarChar(36)
  versionPattern String   @map("version_pattern") @db.VarChar(50) // "2.0.1" or "2.0.*"
  reason         String   @db.Text
  forceUpdateTo  String?  @map("force_update_to") @db.VarChar(30) // which version to push instead
  isActive       Boolean  @default(true) @map("is_active")
  createdAt      DateTime @default(now()) @map("created_at")
  createdBy      String?  @map("created_by") @db.VarChar(36)

  @@index([isActive])
  @@index([versionPattern])
  @@map("blocked_versions")
}
