# =============================================================================
# CCF Admin Portal Backend - Environment Variables
# =============================================================================
# Copy to .env and update for your environment.
# Run 'npm run env:check' to validate your configuration.
# =============================================================================

# --- Core ---
NODE_ENV="development"
PORT=3001

# --- Database ---
DATABASE_URL="mysql://root:password@localhost:3306/ccf_admin_dev"

# --- JWT (generate unique secrets per environment) ---
JWT_SECRET="dev-jwt-secret-not-for-production-use-only"
JWT_REFRESH_SECRET="dev-refresh-secret-not-for-production-use-only"
JWT_EXPIRES_IN="1h"
JWT_REFRESH_EXPIRES_IN="7d"

# --- License HMAC (must match the desktop app for the same environment) ---
CCF_HMAC_SECRET="dev-hmac-secret"

# --- CORS ---
CORS_ORIGIN="http://localhost:5173"

# --- CI/CD Webhook ---
GITHUB_WEBHOOK_SECRET="change-this-to-a-random-64-character-hex-string"

# --- SMTP / Email ---
SMTP_HOST=""
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="noreply@cyberchakra.in"
PORTAL_URL="http://localhost:5173"

# --- Logging ---
LOG_LEVEL="debug"
