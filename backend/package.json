{
  "name": "ccf-admin-backend",
  "version": "1.0.0",
  "description": "Cyber Chakra Forensics Admin Portal - Backend API",
  "private": true,
  "type": "module",
  "scripts": {
    "predev": "tsx src/env-check.ts",
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "prestart": "tsx src/env-check.ts",
    "start": "node dist/index.js",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:seed": "tsx src/seed.ts",
    "db:seed:staging": "tsx src/seed-staging.ts",
    "db:generate": "prisma generate",
    "env:check": "tsx src/env-check.ts",
    "test:integration": "tsx src/__tests__/integration.test.ts",
    "test:compat": "tsx src/__tests__/desktop-compat-live.test.ts",
    "test:full-flow": "tsx src/__tests__/full-flow.test.ts",
    "test:smoke": "tsx src/__tests__/smoke.test.ts",
    "healthcheck": "tsx src/healthcheck.ts"
  },
  "dependencies": {
    "@prisma/client": "^6.4.1",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "date-fns": "^4.1.0",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-rate-limit": "^7.5.0",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^6.9.16",
    "semver": "^7.7.4",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "uuid": "^11.1.0",
    "xss": "^1.0.15",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.13.10",
    "@types/nodemailer": "^6.4.17",
    "@types/semver": "^7.7.1",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.8",
    "@types/uuid": "^10.0.0",
    "nodemon": "^3.1.9",
    "prisma": "^6.4.1",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2"
  }
}
