# =============================================================================
# CCF Admin Portal - Environment Variables
# =============================================================================
# Copy this file to backend/.env and update values for your environment.
#
# Environments:
#   development  - Local machine with Docker MySQL
#   staging      - Hostinger at staging.cyberchakra.online
#   production   - Hostinger at cyberchakra.online
#
# For production, use strong random secrets and restrict CORS_ORIGIN.
# Generate secrets with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# =============================================================================

# --- Environment ---
NODE_ENV="development"

# --- Database ---
# Development: Docker MySQL via docker-compose.yml
# Staging/Production: Hostinger MySQL (Hostinger prefixes DB/user names)
DATABASE_URL="mysql://root:password@localhost:3306/ccf_admin_dev"

# --- JWT Authentication ---
# MUST be unique per environment. MUST be 64+ chars in production.
JWT_SECRET="dev-jwt-secret-not-for-production-use-only"
JWT_REFRESH_SECRET="dev-refresh-secret-not-for-production-use-only"
JWT_EXPIRES_IN="1h"
JWT_REFRESH_EXPIRES_IN="7d"

# --- License Server HMAC ---
# Must match the desktop app's compiled HMAC secret for the same environment.
CCF_HMAC_SECRET="dev-hmac-secret"

# --- Server ---
PORT=3001
CORS_ORIGIN="http://localhost:5173"

# --- CI/CD Webhook (GitHub Actions release pipeline) ---
# Generate with: openssl rand -hex 32
# The same value must be set as ADMIN_PORTAL_WEBHOOK_KEY in GitHub repo secrets.
GITHUB_WEBHOOK_SECRET="change-this-to-a-random-64-character-hex-string"

# --- GitHub API (Release Wizard) ---
# Personal Access Token with repo + actions scope for triggering workflow_dispatch
# and reading releases/workflow runs from the desktop app repository.
GITHUB_PAT=""
GITHUB_REPO_OWNER="SpandeyWoodls"
GITHUB_REPO_NAME="cyber-chakra-forensics"

# --- Frontend (prefix with VITE_ for Vite to expose to client-side code) ---
# In development, leave empty to use Vite proxy (recommended).
# In staging/production, set to the full URL of the admin portal.
VITE_API_URL=""

# --- SMTP / Email Notifications ---
# Leave empty in development to skip email sending.
# Use Mailtrap (https://mailtrap.io) for safe dev/staging email testing.
SMTP_HOST=""
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="noreply@cyberchakra.in"
PORTAL_URL="http://localhost:5173"

# --- Logging ---
# debug | info | warn | error
LOG_LEVEL="debug"
